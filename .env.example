# =============================================================================
# CineSort - Variables d'environnement (template)
# =============================================================================
# Copier en .env (NE PAS COMMIT — deja dans .gitignore) puis adapter.
# Toutes les variables sont OPTIONNELLES : CineSort fonctionne sans .env.
# Les valeurs sont lues depuis os.environ au demarrage du process.
#
# Convention :
#   - Booleens : "1" / "true" / "yes" / "on" pour activer (sinon desactive).
#   - Chemins  : absolus de preference (les expansions ~ et $VAR sont gerees).
# =============================================================================


# === Mode developpeur ========================================================
# DEV_MODE=1 active les outils de preview UI et autorise --ui preview / next.
# En production (release publique), garder DEV_MODE non defini.
# Ref : app.py:DEV_MODE_ENV_VAR, scripts/run_ui_preview.py
# DEV_MODE=0

# Variant d'interface a afficher au boot. Valeurs : stable | preview | next.
# preview/next sont reserves au mode dev (fallback automatique vers stable
# si DEV_MODE n'est pas actif).
# Ref : app.py:resolve_ui_variant
# CINESORT_UI=stable


# === Logging =================================================================
# Niveau de log minimum. Override prioritaire sur le setting "log_level" du
# settings.json. Valeurs : DEBUG | INFO | WARNING | ERROR | CRITICAL.
# Ref : trifilms/infra/log_context.py:resolve_log_level
# CINESORT_LOG_LEVEL=INFO

# TRIFILMS_DEBUG=1 force le niveau DEBUG (alias historique).
# Active aussi des traces verbeuses dans tmdb_client, job_runner et state.
# Ref : trifilms/infra/state.py:_DEBUG_ENV_VALUES
# TRIFILMS_DEBUG=0


# === Stockage local ==========================================================
# LOCALAPPDATA est defini automatiquement par Windows ; ne PAS le surcharger
# sauf cas tres specifique (tests isoles, CI). Pointe vers le dossier qui
# contient %LOCALAPPDATA%\CineSort\ (settings.json, db, logs, backups).
# Ref : app.py, trifilms/infra/state.py
# LOCALAPPDATA=C:\Users\<user>\AppData\Local


# === Tests automatises =======================================================
# CINESORT_TESTING=1 force le mode "tests" : evite la creation du
# %LOCALAPPDATA%\CineSort\ par effet de bord lors d'imports unittest.
# Ref : app.py:_should_skip_state_dir_creation
# CINESORT_TESTING=0

# Tests E2E desktop (Playwright + CDP sur la fenetre pywebview).
# CINESORT_E2E=1 active le port debug remote dans pywebview (CINESORT_CDP_PORT,
# defaut 9222) et debloque les fixtures tests/e2e_desktop/.
# Ref : app.py, tests/e2e_desktop/conftest.py
# CINESORT_E2E=0
# CINESORT_CDP_PORT=9222

# Token API REST utilise par les scripts de test (run_lighthouse.py,
# test_axe_dashboard.py, test_responsive_viewports.py). Recuperable depuis
# settings.json -> rest_api_token apres premier lancement.
# CINESORT_API_TOKEN=

# Chrome/Chromium binaire pour Lighthouse. Si non defini, le script tente
# de detecter Edge automatiquement.
# Ref : scripts/run_lighthouse.py
# CHROME_PATH=

# Tests stress (10000 films simules) — opt-in pour ne pas alourdir la CI.
# Ref : tests/stress/test_10k_films.py
# TRIFILMS_STRESS=0
# TRIFILMS_STRESS_COUNT=10000


# === Tests live (preuves reseau / outils externes) ===========================
# Suite TMDb live : appelle la vraie API TMDb. Necessite une cle valide.
# Ref : tests/live/live_env.py:should_run_tmdb_live
# TRIFILMS_LIVE_TMDB=0
# TRIFILMS_TMDB_API_KEY=

# Suite probe live : verifie ffprobe + mediainfo sur un media reel.
# Si TRIFILMS_MEDIA_SAMPLE_PATH est vide, un media temporaire est genere via
# ffmpeg present dans le PATH.
# Ref : tests/live/live_env.py:should_run_probe_live
# TRIFILMS_LIVE_PROBE=0
# TRIFILMS_FFPROBE_PATH=
# TRIFILMS_MEDIAINFO_PATH=
# TRIFILMS_MEDIA_SAMPLE_PATH=

# Suite pywebview native : verifie le bridge Python <-> JS dans une vraie
# fenetre pywebview. Necessite un environnement graphique.
# Ref : tests/live/live_env.py:should_run_pywebview_live
# TRIFILMS_LIVE_PYWEBVIEW=0


# === Snapshots Playwright ====================================================
# PLAYWRIGHT_UPDATE_SNAPSHOTS=1 regenere les baselines visuelles au lieu de
# comparer. A utiliser apres une refonte UI volontaire.
# Ref : tests/e2e/run_e2e.py
# PLAYWRIGHT_UPDATE_SNAPSHOTS=0

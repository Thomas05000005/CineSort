{
  "_comment": "CineSort - Template settings.json. Stocke par defaut dans %LOCALAPPDATA%/CineSort/settings.json. Ne PAS commit la version reelle (contient cles DPAPI + tokens). JSON ne supporte pas les commentaires natifs : les cles _* sont des marqueurs de section, ignorees par le parser de l'app.",
  "_version_template": "v7.7.0",

  "_section_essentiel": "=== ESSENTIEL (premier lancement) ===",
  "roots": ["C:\\Films"],
  "root": "C:\\Films",
  "state_dir": "%LOCALAPPDATA%\\CineSort",
  "tmdb_api_key": "VOTRE_CLE_API_TMDB",
  "remember_key": true,
  "onboarding_completed": false,
  "expert_mode": false,

  "_section_tmdb": "=== TMDb (metadonnees + posters) ===",
  "tmdb_enabled": true,
  "tmdb_timeout_s": 10.0,

  "_section_probe": "=== ANALYSE VIDEO (ffprobe + mediainfo) ===",
  "probe_backend": "auto",
  "mediainfo_path": "",
  "ffprobe_path": "",
  "probe_timeout_s": 30.0,

  "_section_scan": "=== SCAN ===",
  "incremental_scan_enabled": false,
  "enable_tv_detection": false,
  "subtitle_detection_enabled": true,
  "subtitle_expected_languages": ["fr"],

  "_section_review": "=== REVIEW + APPLY ===",
  "dry_run_apply": true,
  "quarantine_unapproved": false,
  "auto_approve_enabled": false,
  "auto_approve_threshold": 85,
  "auto_quarantine_corrupted": false,

  "_section_naming": "=== PROFIL DE RENOMMAGE ===",
  "naming_preset": "default",
  "naming_movie_template": "{title} ({year})",
  "naming_tv_template": "{series} ({year})",

  "_section_cleanup": "=== NETTOYAGE / COLLECTIONS ===",
  "collection_folder_enabled": true,
  "collection_folder_name": "_Collection",
  "move_empty_folders_enabled": false,
  "empty_folders_folder_name": "_Vide",
  "empty_folders_scope": "root_all",
  "cleanup_residual_folders_enabled": false,
  "cleanup_residual_folders_folder_name": "_Residuels",
  "cleanup_residual_folders_scope": "touched_only",
  "cleanup_residual_include_nfo": true,
  "cleanup_residual_include_images": true,
  "cleanup_residual_include_subtitles": true,
  "cleanup_residual_include_texts": true,

  "_section_jellyfin": "=== INTEGRATION JELLYFIN ===",
  "jellyfin_enabled": false,
  "jellyfin_url": "http://192.168.1.10:8096",
  "jellyfin_api_key": "",
  "jellyfin_user_id": "",
  "jellyfin_refresh_on_apply": true,
  "jellyfin_sync_watched": true,
  "jellyfin_timeout_s": 10.0,

  "_section_plex": "=== INTEGRATION PLEX ===",
  "plex_enabled": false,
  "plex_url": "http://192.168.1.10:32400",
  "plex_token": "",
  "plex_library_id": "",
  "plex_refresh_on_apply": true,
  "plex_timeout_s": 10.0,

  "_section_radarr": "=== INTEGRATION RADARR ===",
  "radarr_enabled": false,
  "radarr_url": "http://192.168.1.10:7878",
  "radarr_api_key": "",
  "radarr_timeout_s": 10.0,

  "_section_notifications": "=== NOTIFICATIONS DESKTOP (Windows) ===",
  "notifications_enabled": false,
  "notifications_scan_done": true,
  "notifications_apply_done": true,
  "notifications_undo_done": true,
  "notifications_errors": true,

  "_section_email": "=== RAPPORT PAR EMAIL (SMTP) ===",
  "email_enabled": false,
  "email_smtp_host": "smtp.gmail.com",
  "email_smtp_port": 587,
  "email_smtp_user": "",
  "email_smtp_password": "",
  "email_smtp_tls": true,
  "email_to": "",
  "email_on_scan": true,
  "email_on_apply": true,

  "_section_watch": "=== MODE PLANIFIE / WATCH FOLDER ===",
  "watch_enabled": false,
  "watch_interval_minutes": 5,

  "_section_plugins": "=== PLUGINS POST-ACTION (dossier ./plugins) ===",
  "plugins_enabled": false,
  "plugins_timeout_s": 30,

  "_section_rest_api": "=== API REST + DASHBOARD DISTANT ===",
  "rest_api_enabled": false,
  "rest_api_port": 8642,
  "rest_api_token": "GENERE_AUTOMATIQUEMENT_AU_PREMIER_LANCEMENT",
  "rest_api_cors_origin": "",
  "rest_api_https_enabled": false,
  "rest_api_cert_path": "",
  "rest_api_key_path": "",

  "_section_updates": "=== MISES A JOUR (GitHub Releases) ===",
  "update_check_enabled": true,
  "auto_check_updates": true,
  "update_check_channel": "stable",
  "update_github_repo": "",
  "update_last_check_ts": 0.0,

  "_section_perceptual": "=== ANALYSE PERCEPTUELLE (signal reel) ===",
  "perceptual_enabled": false,
  "perceptual_auto_on_scan": false,
  "perceptual_auto_on_quality": true,
  "perceptual_timeout_per_film_s": 120,
  "perceptual_frames_count": 10,
  "perceptual_skip_percent": 5,
  "perceptual_dark_weight": 1.5,
  "perceptual_audio_deep": true,
  "perceptual_audio_segment_s": 30,
  "perceptual_comparison_frames": 20,
  "perceptual_comparison_timeout_s": 600,
  "perceptual_parallelism_mode": "auto",
  "perceptual_audio_fingerprint_enabled": true,
  "perceptual_scene_detection_enabled": true,
  "perceptual_audio_spectral_enabled": true,
  "perceptual_ssim_self_ref_enabled": true,
  "perceptual_hdr10_plus_detection_enabled": true,
  "perceptual_interlacing_detection_enabled": true,
  "perceptual_crop_detection_enabled": true,
  "perceptual_judder_detection_enabled": false,
  "perceptual_grain_intelligence_enabled": true,
  "perceptual_audio_mel_enabled": true,
  "perceptual_lpips_enabled": true,

  "_section_appearance": "=== APPARENCE (themes + animations) ===",
  "theme": "studio",
  "animation_level": "moderate",
  "effect_speed": 50,
  "glow_intensity": 30,
  "light_intensity": 20,

  "_section_debug": "=== DEBUG ===",
  "debug_enabled": false,

  "_legend": {
    "_comment_naming_preset": "Valeurs : default | plex | jellyfin | quality | custom",
    "_comment_probe_backend": "Valeurs : auto | mediainfo | ffprobe | none",
    "_comment_empty_folders_scope": "Valeurs : root_all | touched_only",
    "_comment_cleanup_residual_folders_scope": "Valeurs : touched_only | root_all",
    "_comment_perceptual_parallelism_mode": "Valeurs : auto | max | safe | serial",
    "_comment_theme": "Valeurs : studio | cinema | luxe | neon",
    "_comment_animation_level": "Valeurs : subtle | moderate | intense",
    "_comment_update_check_channel": "Valeurs : stable | beta",
    "_comment_secrets": "tmdb_api_key, jellyfin_api_key, plex_token, radarr_api_key, email_smtp_password sont chiffres via DPAPI au premier write_settings (champs *_secret avec scheme/blob_b64 dans le fichier reel)",
    "_comment_rest_api_token": "Token REST genere automatiquement (24 chars urlsafe). Pour exposer le dashboard sur le LAN, le token doit faire >= 32 caracteres (sinon retrogradation transparente vers 127.0.0.1)",
    "_comment_roots": "roots est la liste canonique. root = roots[0] est conserve pour compatibilite descendante (migration auto)"
  }
}

        UI_DESKTOP[web/ pywebview frontend]
        UI_DASHBOARD[web/dashboard/ SPA distante]
        UI_API[trifilms/ui/api/ JS bridge]
    end

    subgraph APP_LAYER["Application Layer"]
        APP_PLAN[plan_support / apply_core]
        APP_JOB[job_runner / cleanup]
        APP_INTEG[jellyfin_sync / plex / radarr]
        APP_HOOKS[plugin_hooks / email / watcher]
    end

    subgraph DOMAIN_LAYER["Domain Layer"]
        DOM_CORE[core / scoring / naming]
        DOM_QUALITY[quality_score / encode_analysis]
        DOM_PERCEPTUAL[perceptual/ 20+ modules]
        DOM_HELPERS[scan / subtitle / tv / edition]
    end

    subgraph INFRA_LAYER["Infrastructure Layer"]
        INFRA_DB[(SQLite WAL<br/>21 migrations)]
        INFRA_PROBE[probe/ ffprobe + mediainfo]
        INFRA_HTTP[tmdb / jellyfin / plex / radarr clients]
        INFRA_REST[rest_server.py]
        INFRA_NOTIF[notifications Win32]
    end


%% 3. Pipeline analyse perceptuelle (DAG)
%% ---------------------------------------------------------------------------
flowchart TB
    INPUT[Video file] --> FFPROBE[ffprobe<br/>duration + streams]
    FFPROBE --> TIMESTAMPS[compute_timestamps<br/>echantillonnage deterministe]
    TIMESTAMPS --> EXTRACT[extract_representative_frames<br/>downscale 4K]

    EXTRACT --> VIDEO_FILTERS[run_filter_graph<br/>signalstats + blockdetect + blurdetect]
    VIDEO_FILTERS --> HISTO[luminance_histogram + banding]
    VIDEO_FILTERS --> GRAIN_V2[grain_analysis v2<br/>era TMDb + AV1 AFGS1]
    VIDEO_FILTERS --> SSIM[ssim_self_ref<br/>1080p vs 4K]
    VIDEO_FILTERS --> LPIPS[LPIPS AlexNet ONNX]

    INPUT --> AUDIO_EBU[loudnorm EBU R128]
    AUDIO_EBU --> ASTATS[astats + clipping]
    ASTATS --> CHROMA[Chromaprint fingerprint]
    ASTATS --> SPECTRAL[spectral cutoff FFT]
    ASTATS --> MEL[Mel spectrogram<br/>4 detecteurs]

    HISTO --> COMPV[compute_visual_score]
    GRAIN_V2 --> COMPV
    SSIM --> COMPV
    LPIPS --> COMPV
    AUDIO_EBU --> COMPA[compute_audio_score]
    SPECTRAL --> COMPA
    MEL --> COMPA

    COMPV --> COMPOSITE[composite_score_v2<br/>Video 60 / Audio 35 / Coherence 5]
    COMPA --> COMPOSITE
    COMPOSITE --> VERDICTS[detect_cross_verdicts<br/>10 verdicts contextualises]
    VERDICTS --> CACHE[(perceptual_reports DB)]

%% ---------------------------------------------------------------------------
%% 4. Notification flow (queue thread-safe -> Win32 toast)
%% ---------------------------------------------------------------------------
sequenceDiagram
    autonumber
    participant USER as Utilisateur
    participant API as TriFilmsApi (UI thread)
    participant JOB as JobRunner (background)
    participant NOTIFY as NotifyService
    participant Q as Queue thread-safe
    participant DRAIN as drain_timer (UI thread)
    participant WIN32 as Shell_NotifyIconW
    participant CENTER as NotificationStore

    USER->>API: start_plan(settings)
    API->>JOB: spawn thread
    JOB->>JOB: scan + plan
    JOB->>NOTIFY: notify(scan_done, payload)
    NOTIFY->>Q: queue.put(event)
    NOTIFY->>CENTER: mirror(event)

    loop chaque 250ms
        DRAIN->>Q: drain_queue()
        Q-->>DRAIN: events[]
        alt window non focus
            DRAIN->>WIN32: Shell_NotifyIconW(BALLOON)
            WIN32-->>USER: toast OS
        else window focus
            DRAIN->>DRAIN: skip OS toast
        end
    end

    USER->>API: open notification center
    API->>CENTER: get_notifications()
    CENTER-->>USER: liste persistante

%% ---------------------------------------------------------------------------
%% 5. Apply atomicity (WAL pattern apply_pending_moves)
%% ---------------------------------------------------------------------------
sequenceDiagram
    autonumber
    participant APP as apply_core
    participant DB as SQLite (WAL mode)
    participant FS as Filesystem
    participant BOOT as reconcile_at_boot

    Note over APP,FS: Move atomique (move_journal.journaled_move)
    APP->>DB: INSERT apply_pending_moves<br/>(src, dst, batch_id)
    APP->>FS: shutil.move(src, dst)
    alt move OK
        APP->>DB: DELETE pending_move WHERE id=?
        APP->>DB: INSERT apply_operations<br/>(record_op + checksum)
    else move erreur
        APP->>DB: DELETE pending_move WHERE id=?
        APP-->>APP: raise -> rollback batch
    end

    Note over BOOT,FS: Boot suivant : crash recovery
    BOOT->>DB: SELECT * FROM apply_pending_moves
    loop chaque pending orphelin
        BOOT->>FS: stat(src) + stat(dst)
        alt dst existe (move OK avant crash)
            BOOT->>DB: DELETE pending (verdict completed)
        else src existe seul (crash avant move)
            BOOT->>DB: DELETE pending (verdict rolled_back)
        else les deux existent
            BOOT->>DB: DELETE + alerte UI (duplicated)
        else ni l'un ni l'autre
            BOOT->>DB: DELETE + alerte UI (lost)
        end
    end


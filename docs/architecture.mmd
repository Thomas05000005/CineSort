%% ---------------------------------------------------------------------------
%% 2. Workflow scan -> plan -> review -> apply -> undo
%% ---------------------------------------------------------------------------
flowchart LR
    START([Utilisateur lance scan]) --> SCAN{scan_helpers<br/>incremental v2}
    SCAN -- cache hit total --> PLAN_DONE
    SCAN -- miss / partiel --> NORM[probe_service<br/>ffprobe + mediainfo]
    NORM --> EXTRACT[title_helpers<br/>NFO / dossier / TMDb]
    EXTRACT --> PLAN[plan_support._plan_item<br/>quality + dedup + warnings]
    PLAN --> PLAN_DONE[(plan.jsonl + DB)]

    PLAN_DONE --> REVIEW[/Review UI<br/>approve / reject / bulk/]
    REVIEW -- auto_approve >= seuil --> AUTO[Auto-approuve]
    REVIEW -- saisie manuelle --> SAVE[save_validation]
    AUTO --> SAVE

    SAVE --> DRYRUN{Dry-run apply}
    DRYRUN -- conflits --> REVIEW
    DRYRUN -- OK --> APPLY[apply_core.apply_rows<br/>journal WAL atomique]
    APPLY --> NOTIF[NotifyService toast OS]
    APPLY --> JF[Hook Jellyfin/Plex<br/>refresh + watched]

    APPLY --> END_OK([Termine])
    END_OK -.undo demande.-> UNDO[undo_last_apply<br/>par batch ou par film]
    UNDO --> REVERSE[Reverse moves<br/>conflits -> _undo_conflicts]
    REVERSE --> END_OK

